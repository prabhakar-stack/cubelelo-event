// Cubelelo Events Platform — Prisma Schema
// Phase 1 — Full Data Model
// Add DATABASE_URL to .env.local to connect a PostgreSQL database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Setup:
//   1. Add DATABASE_URL to .env.local
//   2. Run: npx prisma generate        (generate the Prisma Client types)
//   3. Run: npx prisma db push         (push schema to your database)

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User & Profile ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Cubing profile
  wcaId         String?   @unique   // e.g. "2014ABCD01"
  displayName   String?             // custom display name / alias
  country       String?
  role          UserRole  @default(ATHLETE)

  // Relations
  accounts      Account[]
  sessions      AuthSession[]
  solves        Solve[]
  cubeSessions  CubeSession[]
  competitionEntries CompetitionEntry[]
  competitionSolves  CompetitionSolve[]
  dailyChallengeEntries DailyChallengeEntry[]
  practiceSessions PracticeSessionRecord[]
}

enum UserRole {
  ATHLETE
  ADMIN
  DELEGATE
}

// ─── Timer / Session Data ─────────────────────────────────────────────────────

model CubeSession {
  id          String   @id @default(cuid())
  userId      String
  name        String
  puzzleType  String   // '3x3x3', '2x2x2', '4x4x4', 'OH', 'Pyraminx', 'Megaminx'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  solves      Solve[]
}

model Solve {
  id          String      @id @default(cuid())
  userId      String
  sessionId   String
  puzzleType  String
  timeInMs    Int                      // raw milliseconds
  scramble    String      @db.Text
  status      SolveStatus @default(OK) // OK, PLUS_TWO, DNF
  notes       String?
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     CubeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum SolveStatus {
  OK
  PLUS_TWO
  DNF
}

// ─── Competition ──────────────────────────────────────────────────────────────

model Competition {
  id            String            @id @default(cuid())
  name          String
  description   String?           @db.Text
  puzzleType    String            // '3x3x3', '2x2x2', etc.
  startDate     DateTime
  endDate       DateTime
  entryFee      Int               @default(0)  // in paise (INR × 100)
  maxEntries    Int               @default(100)
  status        CompetitionStatus @default(DRAFT)
  rounds        Int               @default(1)
  currentRound  Int               @default(1)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  entries       CompetitionEntry[]
  solves        CompetitionSolve[]
  scrambles     CompetitionScramble[]
}

enum CompetitionStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  LIVE
  COMPLETED
  CANCELLED
}

model CompetitionEntry {
  id              String   @id @default(cuid())
  competitionId   String
  userId          String
  registeredAt    DateTime @default(now())
  paymentStatus   PaymentStatus @default(PENDING)
  paymentId       String?  // Razorpay payment ID
  
  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([competitionId, userId])
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  WAIVED  // For free competitions
}

model CompetitionScramble {
  id            String   @id @default(cuid())
  competitionId String
  round         Int
  attemptNumber Int      // 1-5
  scramble      String   @db.Text
  
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([competitionId, round, attemptNumber])
}

model CompetitionSolve {
  id              String      @id @default(cuid())
  competitionId   String
  userId          String
  round           Int
  attemptNumber   Int         // 1-5
  timeInMs        Int?        // null = DNF
  scramble        String      @db.Text
  status          SolveStatus @default(OK)
  submittedAt     DateTime    @default(now())

  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([competitionId, userId, round, attemptNumber])
}

// ─── Practice Mode ────────────────────────────────────────────────────────────

model DailyChallenge {
  id          String   @id @default(cuid())
  date        String   @unique  // "YYYY-MM-DD" — one per day
  puzzleType  String
  scramble    String   @db.Text
  createdAt   DateTime @default(now())

  entries     DailyChallengeEntry[]
}

model DailyChallengeEntry {
  id               String         @id @default(cuid())
  dailyChallengeId String
  userId           String
  timeInMs         Int?
  status           SolveStatus    @default(OK)
  submittedAt      DateTime       @default(now())

  challenge        DailyChallenge @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dailyChallengeId, userId])
}

model PracticeSessionRecord {
  id          String   @id @default(cuid())
  userId      String
  puzzleType  String
  algId       String?  // if drilling a specific OLL/PLL case
  timeInMs    Int
  scramble    String   @db.Text
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
